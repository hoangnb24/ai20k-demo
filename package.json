{
  "name": "ai20k-demo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @ai20k-demo/db db:push",
    "db:studio": "turbo -F @ai20k-demo/db db:studio",
    "db:generate": "turbo -F @ai20k-demo/db db:generate",
    "db:migrate": "turbo -F @ai20k-demo/db db:migrate",
    "db:seed:demo": "turbo -F @ai20k-demo/db db:seed:demo",
    "db:manipulate:demo": "turbo -F @ai20k-demo/db db:manipulate:demo",
    "db:start": "turbo -F @ai20k-demo/db db:start",
    "db:watch": "turbo -F @ai20k-demo/db db:watch",
    "db:stop": "turbo -F @ai20k-demo/db db:stop",
    "db:down": "turbo -F @ai20k-demo/db db:down"
  },
  "dependencies": {
    "@ai20k-demo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai20k-demo/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.21"
}
