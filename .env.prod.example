# Public host settings
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# App image built by GitHub Actions and pulled by the VPS
WEB_IMAGE=ghcr.io/hoangnb24/ai20k-demo/web:master

# App runtime
NODE_ENV=production
CORS_ORIGIN=https://app.example.com
DATABASE_URL=postgresql://ai20k_demo:change-me@postgres:5432/ai20k_demo
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Postgres
POSTGRES_DB=ai20k_demo
POSTGRES_USER=ai20k_demo
POSTGRES_PASSWORD=change-me

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
